<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        CVE-2025-68161 is flagged against log4j-api, however this CVE applies only
        to log4j-core (the implementation). log4j-api is the interface-only artifact
        and does not contain the vulnerable code. This is a known false positive.
        Reference: https://logging.apache.org/log4j/2.x/security.html
    -->
    <suppress>
        <notes>False positive: CVE-2025-68161 only affects log4j-core, not log4j-api</notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-api@.*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>
</suppressions>
